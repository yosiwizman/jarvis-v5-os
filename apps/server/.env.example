# AKIOR Server Environment Variables
#
# Copy this file to .env and configure for your environment
# NEVER commit .env files with real secrets
#
# For Fly.io deployment, set these via: flyctl secrets set KEY=value
#

# Server Configuration
# PORT is auto-set by Fly.io; only set locally if needed
# PORT=1234

# OpenAI API Configuration (required for AI features)
OPENAI_API_KEY=
# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=

# Weather API (optional)
OPENWEATHER_API_KEY=

# Web Search (optional)
SERPAPI_API_KEY=

# Local LLM (optional)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL_NAME=

# Google OAuth (for Gmail/Calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
