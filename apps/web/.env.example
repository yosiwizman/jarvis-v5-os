# Jarvis V6 Environment Variables
#
# Copy this file to .env.local and configure for your environment
#
# For Vercel deployment, set these in Vercel Dashboard > Settings > Environment Variables
#

# Backend API URL (Fastify server on Fly.io)
# Local: https://localhost:1234
# Production: https://jarvis-server.fly.dev (your Fly.io app URL)
NEXT_PUBLIC_API_URL=https://localhost:1234

# WebSocket/Socket.IO URL (same as API URL for Fly.io deployments)
NEXT_PUBLIC_SOCKET_URL=https://localhost:1234

# Ubuntu Shell / Kiosk Mode (optional)
# Set to "kiosk" when running Jarvis as an Ubuntu shell
# This enables kiosk-specific UI optimizations
# Leave unset for normal development mode
# NEXT_PUBLIC_JARVIS_UBUNTU_MODE=kiosk
