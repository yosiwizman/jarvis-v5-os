:root {
  --akior-idle-opacity: 1;
  --akior-listening-opacity: 0;
  --akior-speaking-opacity: 0;
  --akior-thinking-opacity: 0;
  --akior-transition: 220ms ease;
  --akior-audio-level: 0;
}

.akior {
  position: relative;
  display: inline-block;
  isolation: isolate;
  user-select: none;
  transform: translateZ(0);
}

.akior__asset,
.akior__fx {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.akior__asset {
  object-fit: contain;
  transition:
    opacity var(--akior-transition),
    transform var(--akior-transition),
    filter var(--akior-transition);
  will-change: transform, opacity, filter;
}

.akior__asset--idle { opacity: var(--akior-idle-opacity); }
.akior__asset--listening { opacity: var(--akior-listening-opacity); }
.akior__asset--speaking { opacity: var(--akior-speaking-opacity); }
.akior__asset--thinking { opacity: var(--akior-thinking-opacity); }

.akior__fx--outer-ring,
.akior__fx--counter-ring,
.akior__fx--pulse,
.akior__fx--bloom {
  border-radius: 9999px;
}

.akior__fx--outer-ring {
  transform-origin: 50% 50%;
}

.akior__fx--counter-ring {
  inset: 11%;
  border: 1px solid rgba(115, 251, 255, 0.06);
  box-shadow: 0 0 24px rgba(115, 251, 255, 0.06);
  transform-origin: 50% 50%;
}

.akior__fx--pulse {
  inset: 41%;
  background:
    radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(150,255,255,0.38) 34%, rgba(0,220,255,0) 72%);
  filter: blur(8px);
  opacity: 0.78;
}

.akior__fx--bloom {
  inset: 28%;
  background:
    radial-gradient(circle, rgba(80,245,255,0.22) 0%, rgba(80,245,255,0.08) 42%, rgba(80,245,255,0) 76%);
  filter: blur(20px);
  opacity: 0.5;
}

/* Base motion */
.akior:not(.akior--reduced) .akior__fx--outer-ring {
  animation: akior-spin-outer 24s linear infinite;
}

.akior:not(.akior--reduced) .akior__fx--counter-ring {
  animation: akior-spin-inner 34s linear infinite;
}

.akior:not(.akior--reduced) .akior__fx--pulse {
  animation: akior-breathe 3.8s ease-in-out infinite;
}

/* Idle */
.akior--idle {
  --akior-idle-opacity: 1;
  --akior-listening-opacity: 0;
  --akior-speaking-opacity: 0;
  --akior-thinking-opacity: 0;
}

/* Listening */
.akior--listening {
  --akior-idle-opacity: 0.16;
  --akior-listening-opacity: 1;
  --akior-speaking-opacity: 0;
  --akior-thinking-opacity: 0;
}

.akior--listening:not(.akior--reduced) .akior__fx--outer-ring {
  animation-duration: 16s;
}

.akior--listening:not(.akior--reduced) .akior__fx--counter-ring {
  animation-duration: 26s;
}

.akior--listening .akior__fx--pulse {
  opacity: calc(0.82 + (var(--akior-audio-level) * 0.18));
  transform: scale(calc(1 + (var(--akior-audio-level) * 0.06)));
}

/* Speaking */
.akior--speaking {
  --akior-idle-opacity: 0;
  --akior-listening-opacity: 0;
  --akior-speaking-opacity: 1;
  --akior-thinking-opacity: 0;
}

.akior--speaking:not(.akior--reduced) .akior__fx--outer-ring {
  animation-duration: 10s;
}

.akior--speaking:not(.akior--reduced) .akior__fx--counter-ring {
  animation-duration: 18s;
}

.akior--speaking .akior__fx--pulse {
  opacity: calc(0.9 + (var(--akior-audio-level) * 0.1));
  transform: scale(calc(1.04 + (var(--akior-audio-level) * 0.16)));
  filter: blur(calc(8px + (var(--akior-audio-level) * 4px)));
}

/* Thinking */
.akior--thinking {
  --akior-idle-opacity: 0;
  --akior-listening-opacity: 0;
  --akior-speaking-opacity: 0;
  --akior-thinking-opacity: 1;
}

.akior--thinking:not(.akior--reduced) .akior__fx--outer-ring {
  animation-duration: 20s;
}

.akior--thinking:not(.akior--reduced) .akior__fx--counter-ring {
  animation-duration: 9s;
  animation-direction: reverse;
}

.akior--thinking .akior__fx--pulse {
  opacity: 0.72;
  animation-duration: 1.7s;
}

/* Reduced motion */
.akior--reduced .akior__asset,
.akior--reduced .akior__fx {
  animation: none !important;
  transition-duration: 140ms;
}

.akior--reduced .akior__fx--counter-ring,
.akior--reduced .akior__fx--outer-ring {
  opacity: 0.5;
}

@keyframes akior-spin-outer {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes akior-spin-inner {
  from { transform: rotate(0deg); }
  to { transform: rotate(-360deg); }
}

@keyframes akior-breathe {
  0%, 100% { transform: scale(0.985); opacity: 0.72; }
  50% { transform: scale(1.02); opacity: 1; }
}
