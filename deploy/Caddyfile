# AKIOR Caddy Reverse Proxy Configuration
#
# Routes requests to appropriate backend services:
# - /socket.io/* -> server (WebSocket support)
# - /api/*       -> server (preserves /api prefix for backend)
# - /files/*     -> server (static files)
# - /static/*    -> server (static assets)
# - /*           -> web (Next.js frontend)
#
# Listens on:
#   - :443  (HTTPS - secure, camera/mic enabled)
#   - :80   (HTTP fallback + redirect to HTTPS)
#   - :3000 (localhost for Tailscale Serve)
#
# TLS:
#   Uses Caddy's internal CA (tls internal) for automatic certificate generation.
#   Export the CA with: docker cp jarvis-caddy:/data/caddy/pki/authorities/local/root.crt ./caddy-root-ca.crt
#   Then import on Windows to trust HTTPS connections.

# ============================================
# HTTPS - Primary secure access (camera works here)
# ============================================
akior.home.arpa, akior.local, jarvis.local, aifactory-lan {
    # Use Caddy's internal CA for automatic cert generation
    tls internal

    # Web build info - goes to web container (for drift detection)
    handle /web-build {
        header Cache-Control "no-store, no-cache, must-revalidate"
        header Pragma "no-cache"
        reverse_proxy web:3001
    }

    # Health endpoints - never cache (deployment drift prevention)
    handle /api/health/* {
        header Cache-Control "no-store, no-cache, must-revalidate"
        header Pragma "no-cache"
        reverse_proxy server:1234
    }

    # Socket.IO with WebSocket support
    handle /socket.io/* {
        reverse_proxy server:1234
    }

    # API routes - backend expects /api/* paths
    handle /api/* {
        reverse_proxy server:1234
    }

    # Static files served by backend
    handle /files/* {
        reverse_proxy server:1234
    }

    handle /static/* {
        reverse_proxy server:1234
    }

    # Everything else goes to Next.js web frontend
    # HTML should not be cached to prevent stale bundle references
    handle {
        header Cache-Control "no-store, no-cache, must-revalidate"
        reverse_proxy web:3001
    }

    # Logging
    log {
        output stdout
        format console
        level INFO
    }
}

# ============================================
# HTTP - Fallback for recovery (camera won't work)
# ============================================
:80, :3000 {
    # Force HTTPS for canonical hostnames (keep IP-based HTTP for recovery)
    @secureHosts host akior.local jarvis.local aifactory-lan
    redir @secureHosts https://akior.local{uri} 308

    # Web build info - goes to web container (for drift detection)
    handle /web-build {
        header Cache-Control "no-store, no-cache, must-revalidate"
        header Pragma "no-cache"
        reverse_proxy web:3001
    }

    # Health endpoints - never cache (deployment drift prevention)
    handle /api/health/* {
        header Cache-Control "no-store, no-cache, must-revalidate"
        header Pragma "no-cache"
        reverse_proxy server:1234
    }

    # Socket.IO with WebSocket support
    handle /socket.io/* {
        reverse_proxy server:1234
    }

    # API routes - backend expects /api/* paths
    handle /api/* {
        reverse_proxy server:1234
    }

    # Static files served by backend
    handle /files/* {
        reverse_proxy server:1234
    }

    handle /static/* {
        reverse_proxy server:1234
    }

    # Everything else goes to Next.js web frontend
    # HTML should not be cached to prevent stale bundle references
    handle {
        header Cache-Control "no-store, no-cache, must-revalidate"
        reverse_proxy web:3001
    }

    # Logging
    log {
        output stdout
        format console
        level INFO
    }
}
