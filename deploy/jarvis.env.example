# AKIOR Server Environment Variables for Local Host Deployment
#
# Copy this file to jarvis.env and configure:
#   cp jarvis.env.example jarvis.env
#   nano jarvis.env
#
# NEVER commit jarvis.env with real secrets!

# OpenAI API Configuration (required for AI features)
OPENAI_API_KEY=

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=

# Weather API (optional)
OPENWEATHER_API_KEY=

# Web Search (optional)
SERPAPI_API_KEY=

# Local LLM (optional - for offline/private AI)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL_NAME=


# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
