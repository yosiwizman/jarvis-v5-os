# Tailscale Authentication Key (Phase B.1 — optional remote access)
#
# This file is an EXAMPLE. To enable Tailscale:
# 1. Copy this file to: deploy/secrets/tailscale.env
# 2. Generate an auth key at: https://login.tailscale.com/admin/settings/keys
#    - Choose: Reusable, ephemeral (recommended for containerized deployments)
# 3. Replace YOUR_TAILSCALE_AUTH_KEY_HERE with your actual key
# 4. Bring up the profile: docker compose --profile remote-access up -d
#
# NEVER commit the real tailscale.env file to git (it's gitignored).

TS_AUTHKEY=YOUR_TAILSCALE_AUTH_KEY_HERE
